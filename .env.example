# NMOS System Monitoring Dashboard — environment

# Registry (required): host and port for the IS-04 Query API
NMOS_REGISTRY_HOST=127.0.0.1
NMOS_REGISTRY_PORT=3211

# Optional: full URL instead of host (protocol/host/path parsed; port still set via NMOS_REGISTRY_PORT if needed)
# NMOS_REGISTRY_URL=http://127.0.0.1:3211

# Optional registry settings
# NMOS_REGISTRY_PROTOCOL=http
# NMOS_QUERY_API_VERSION=v1.3
# NMOS_QUERY_BASE_PATH=/x-nmos/query
# NMOS_REGISTRY_SECURE_WS=false

# Optional path to YAML config file (env overrides file)
# NMOS_CONFIG_PATH=config.yaml

# Logging: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Next.js / app listen port
PORT=3000
